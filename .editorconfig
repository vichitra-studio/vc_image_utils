# EditorConfig — consistent editor behaviour across the project.
# https://editorconfig.org  (most editors support it natively or via a plugin)
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# YAML and JSON use 2-space indentation by convention.
[*.{yml,yaml,json}]
indent_size = 2

# Go uses tabs — gofmt enforces this; editorconfig must agree.
[*.go]
indent_style = tab
indent_size = 4

# Markdown uses trailing whitespace for hard line breaks.
[*.md]
trim_trailing_whitespace = false
